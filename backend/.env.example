PORT=5000

# Database — MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/hmp_oj?retryWrites=true&w=majority

# Auth
JWT_SECRET=your_super_secret_key_here
CLIENT_ID=your_google_oauth_client_id
CLIENT_SECRET=your_google_oauth_client_secret

# Code Execution — Judge0 via RapidAPI
JUDGE0_API_KEY=your_judge0_rapidapi_key

# Redis — Upstash (cloud) or localhost (local Docker)
REDIS_URL=rediss://default:<password>@your-upstash-endpoint.upstash.io:6379
# For local Docker use these instead:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# RabbitMQ — CloudAMQP (cloud) or localhost (local Docker)
RABBITMQ_URL=amqps://<user>:<password>@capybara.lmq.cloudamqp.com/<vhost>
# For local Docker use: amqp://localhost

# Frontend URL (for CORS)
CLIENT_ORIGIN=https://your-frontend.vercel.app
